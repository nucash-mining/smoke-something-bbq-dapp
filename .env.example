# Copy this file to ".env" and fill in your values, then restart `npm run dev`.
# If you leave Supabase blank, the app runs in OFFLINE DEMO mode (data is stored
# in your browser only) so you can click through everything before going live.

# --- Supabase (Dashboard > Project Settings > API) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Owner account ---
# The email that unlocks the owner dashboard. Must match the account you sign in
# with AND the email you put in the `admins` table in supabase/schema.sql.
VITE_OWNER_EMAIL=

# Offline-demo owner passcode (only used when Supabase is NOT configured).
VITE_DEMO_OWNER_PASSCODE=bbq-owner
